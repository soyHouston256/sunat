function buildDashboard(rows){
  const meses=['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  const monthBase=Array(12).fill(0), dayBase=Array(31).fill(0);
  const lugarMap={}, catMap={};
  let totalBase=0, totalDed=0, totalCount=0, maxTicket=0, minTicket=Infinity;

  rows.forEach(r=>{
    const base=parseMoney(r['MONTO BASE DE DEDUCCION EN SOLES']);
    const ded=parseMoney(r['MONTO DEDUCIBLE EN SOLES']);
    const fecha=(r['FECHA DE COMPROBANTE']??'').toString();
    const nombre=(r['NOMBRE o RAZON SOCIAL']??'').toString().trim();
    if(ded>0) totalDed+=ded;
    if(!base) return;
    totalBase+=base; totalCount++;
    if(base>maxTicket) maxTicket=base;
    if(base<minTicket) minTicket=base;
    if(fecha.includes('/')){
      const m=parseInt(fecha.split('/')[1])-1;
      const d=parseInt(fecha.split('/')[0])-1;
      if(m>=0&&m<12) monthBase[m]+=base;
      if(d>=0&&d<31) dayBase[d]+=base;
    }
    if(nombre) lugarMap[nombre]=(lugarMap[nombre]||0)+base;
    catMap[cat(nombre)]=(catMap[cat(nombre)]||0)+base;
  });

  data = {totalBase,totalDed,totalCount,monthBase,dayBase,lugarMap,catMap,maxTicket,minTicket,_fastUpload:(Date.now()-_uploadStartTime)<10000};
  storyData = data;
  checkEasterEggs(data);

  const profile=PROFILES.find(p=>p.match(data))||PROFILES[5];
