<nav>
  <div><div class="logo">SUNAT WRAPPED</div><div class="logo-sub">tu año en boletas 🇵🇪</div></div>
  <div class="year-badge">2025</div>
</nav>

<!-- UPLOAD -->
<div id="uploadScreen">
  <!-- Inti Sol Inca -->
  <div class="inti-wrap" id="intiWrap">
    <svg class="inti-sun" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <!-- Rays -->
      <line x1="50" y1="6" x2="50" y2="24" stroke="#D4A017" stroke-width="4.5" stroke-linecap="round"/>
      <line x1="50" y1="76" x2="50" y2="94" stroke="#D4A017" stroke-width="4.5" stroke-linecap="round"/>
      <line x1="6" y1="50" x2="24" y2="50" stroke="#D4A017" stroke-width="4.5" stroke-linecap="round"/>
      <line x1="76" y1="50" x2="94" y2="50" stroke="#D4A017" stroke-width="4.5" stroke-linecap="round"/>
      <line x1="19" y1="19" x2="31" y2="31" stroke="#D4A017" stroke-width="4" stroke-linecap="round"/>
      <line x1="69" y1="69" x2="81" y2="81" stroke="#D4A017" stroke-width="4" stroke-linecap="round"/>
      <line x1="81" y1="19" x2="69" y2="31" stroke="#D4A017" stroke-width="4" stroke-linecap="round"/>
      <line x1="19" y1="81" x2="31" y2="69" stroke="#D4A017" stroke-width="4" stroke-linecap="round"/>
      <!-- Body -->
      <circle cx="50" cy="50" r="22" fill="#D4A017"/>
      <circle cx="50" cy="50" r="18" fill="#F0C040"/>
      <!-- Face -->
      <ellipse cx="43" cy="46" rx="3" ry="3.5" fill="#2C1810"/>
      <ellipse cx="57" cy="46" rx="3" ry="3.5" fill="#2C1810"/>
      <path d="M43 57 Q50 63 57 57" stroke="#2C1810" stroke-width="2.5" fill="none" stroke-linecap="round"/>
      <circle cx="43" cy="45" r="1.2" fill="#F0C040"/>
      <circle cx="57" cy="45" r="1.2" fill="#F0C040"/>
    </svg>
