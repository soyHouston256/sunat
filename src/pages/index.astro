// ── ESCALINATA PROGRESS ──
const STEPS = 12;
let escalinataTick = 0;
let escalinataTimer = null;
function initEscalinata(){
  const steps = $('escalinataSteps');
  if(!steps) return;
  steps.innerHTML = Array.from({length:STEPS},(_,i)=>{
    const h = 20 + Math.round((i/STEPS)*60);
    return `<div class="esc-step" id="esc${i}" style="height:${h}%"></div>`;
  }).join('');
  escalinataTick = 0;
  updateEscalinata(0);
}
function updateEscalinata(pct){
  const lit = Math.round((pct/100)*STEPS);
  for(let i=0;i<STEPS;i++){
    const s = $('esc'+i);
    if(s) s.classList.toggle('lit', i < lit);
  }
  const chasqui = $('escalinaChasqui');
  if(chasqui){
    const trackW = (chasqui.parentElement?.offsetWidth||280) - 36;
    chasqui.style.left = Math.max(4, Math.round((pct/100)*trackW)) + 'px';
  }
  const pctEl = $('escalinaPct');
  if(pctEl) pctEl.textContent = Math.round(pct)+'%';
}

let msgIdx=0,msgTimer;
function cycleMsg(){
  $('loadMsg').style.opacity='0';
  const pct = Math.min(90, (msgIdx / (loadMsgs.length-1)) * 90);
  updateEscalinata(pct);
  setTimeout(()=>{$('loadMsg').textContent=loadMsgs[msgIdx%loadMsgs.length];$('loadMsg').style.opacity='1';msgIdx++;},300);
}

// ── GOLD RAIN ANIMATION ──
function startGoldRain(canvasId){
  const canvas = document.getElementById(canvasId);
  if(!canvas) return;
  const rect = canvas.parentElement.getBoundingClientRect();
  canvas.width = rect.width||430;
  canvas.height = rect.height||763;
  const ctx = canvas.getContext('2d');
  const coins = Array.from({length:35},()=>({
    x: Math.random()*canvas.width,
    y: Math.random()*-canvas.height,
    size: Math.random()*16+8,
    speed: Math.random()*1.5+0.8,
    opacity: Math.random()*0.6+0.3,
    rot: Math.random()*360,
    vrot: (Math.random()-.5)*4,
    symbol: Math.random()>0.5 ? 'S/' : '✦',
  }));
  let alive = true;
  function tick(){
    if(!alive) return;
    ctx.clearRect(0,0,canvas.width,canvas.height);
    coins.forEach(c=>{
      c.y += c.speed; c.rot += c.vrot;
      if(c.y > canvas.height+20) c.y = -20;
      ctx.save();
      ctx.globalAlpha = c.opacity * 0.55;
      ctx.translate(c.x, c.y);
      ctx.rotate(c.rot*Math.PI/180);
      ctx.fillStyle = '#D4A017';
      ctx.font = `bold ${c.size}px 'Syne',sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(c.symbol, 0, 0);
      ctx.restore();
    });
    requestAnimationFrame(tick);
  }
  tick();
  return ()=>{ alive=false; };
}
let stopGoldRain = null;

// ── COUNTER ANIMATION ──
function animateCounter(el, target, duration=1800){
  if(!el) return;
  const start = performance.now();
  const t = parseFloat(target);
  function step(now){
    const p = Math.min(1,(now-start)/duration);
    const ease = 1-Math.pow(1-p,3);
    const cur = Math.round(t*ease);
    el.textContent = 'S/ '+cur.toLocaleString('es-PE');
    if(p<1) requestAnimationFrame(step);
    else el.textContent = 'S/ '+t.toLocaleString('es-PE',{minimumFractionDigits:0,maximumFractionDigits:0});
  }
  requestAnimationFrame(step);
}

// ── EASTER EGGS ──
function showEasterToast(icon, msg){
  const t = $('easterToast');
  if(!t) return;
  t.innerHTML = `<span class="easter-icon">${icon}</span>${msg}`;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 5000);
}

function checkEasterEggs(d){
  const {totalBase, catMap, totalCount} = d;
  const polleria = catMap['Pollería']||0;
  const restaurant = totalBase - (catMap['Supermercado']||0) - (catMap['Otro']||0);

  // Easter egg 1: Pishtaco (gasto total en un rubro cercano a 666)
  const vals = Object.values(catMap);
  const hasDevil = vals.some(v=>Math.abs(v-666)<5);
  if(hasDevil){
    setTimeout(()=>showEasterToast('👻','El Pishtaco detectado en tus gastos. Cuidado al salir de noche, causita.'),2000);
    return;
  }
  // Easter egg 2: Rey del pollo
  if(polleria > 1000){
    setTimeout(()=>showEasterToast('🍗','Más de S/1,000 en pollo a la brasa. El Inca te habría dado tierras, hermano.'),2000);
    return;
  }
  // Easter egg 3: El ermitaño
  const comidaOut = (catMap['Restaurante']||0)+(catMap['Pollería']||0)+(catMap['Mariscos']||0)+(catMap['Café']||0)+(catMap['Comida asiática']||0)+(catMap['Pizzería']||0);
  if(comidaOut < 50 && totalCount > 5){
    setTimeout(()=>showEasterToast('🥘','Casi nada en restaurantes. ¿Cocinaste todo el año como un verdadero peruano del Incanato?'),2000);
    return;
  }
  // Easter egg 4: El chasqui (muchas boletas = velocidad)
  if(totalCount > 200){
    setTimeout(()=>showEasterToast('🏃','¡Más de 200 boletas! Eres más rápido que un Chasqui del Tawantinsuyu.'),2000);
  }
}

let soundEnabled = false;
function toggleSound() {
  soundEnabled = !soundEnabled;
  document.getElementById('soundBtn').textContent = soundEnabled ? '🔊' : '🔇';
}
function playCoinSound() {
  if (!soundEnabled) return;
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.setValueAtTime(1200, ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(800, ctx.currentTime + 0.1);
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.25);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.25);
  } catch(e) {}
}

function processFile(file){
  _uploadStartTime = Date.now();
  $('uploadScreen').style.display='none';
  $('loadingScreen').style.display='flex';
  $('loadMsg').style.transition='opacity 0.3s';
  initEscalinata();
  msgIdx=0;cycleMsg();msgTimer=setInterval(cycleMsg,1600);
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const wb=XLSX.read(e.target.result,{type:'array'});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const rows=XLSX.utils.sheet_to_json(ws,{defval:''});
      clearInterval(msgTimer);
      updateEscalinata(100);
      if(!rows.length){alert('No se encontraron datos.');resetApp();return;}
      setTimeout(()=>buildDashboard(rows),600);
    }catch(err){clearInterval(msgTimer);alert('Error: '+err.message);resetApp();}
  };
  reader.readAsArrayBuffer(file);
}

function resetApp(){
  destroyCharts();
  closeStories();
  $('dashboard').style.display='none';
  $('uploadScreen').style.display='flex';
  $('fileInput').value='';
  data=null;storyData=null;
}

$('fileInput').addEventListener('change',e=>{if(e.target.files[0])processFile(e.target.files[0]);});
const dz=$('dropZone');
dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('drag');});
dz.addEventListener('dragleave',()=>dz.classList.remove('drag'));
dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('drag');if(e.dataTransfer.files[0])processFile(e.dataTransfer.files[0]);});

