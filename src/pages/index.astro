  $('s1').textContent=fmtK(totalBase);
  $('s2').textContent=totalCount;
  $('s3').textContent=fmtK(totalDed);

  buildComparativa(data);

  const maxMes=monthBase.indexOf(Math.max(...monthBase));
  const topLugar=Object.entries(lugarMap).sort((a,b)=>b[1]-a[1])[0];
  const avgTicket=totalBase/totalCount;
