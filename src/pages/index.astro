function parseMoney(v){
  if(typeof v==='number') return v;
  if(typeof v==='string'){const n=parseFloat(v.trim().replace(/\s/g,'').replace(',','.'));return isNaN(n)?0:n;}
  return 0;
}

function cat(name){
  const n=name.toUpperCase();
  if(/STARBUCKS|CAFE|CHEF|VIENA|COREST|CERO CULP/.test(n)) return 'Café';
  if(/CHIFA|TANG|FON WA|SUSHI|NENGFENG|OKINAGA|MADAM TUSAN|FONG SEN|LONG YAN|NARUTO|ORIENTAL/.test(n)) return 'Comida asiática';
  if(/CEBICH|PULPO|PESQUERO|MARISCO|TERMINAL/.test(n)) return 'Mariscos';
  if(/PIZZA|ROMANA|PAPA JOHNS/.test(n)) return 'Pizzería';
  if(/BURGER|KFC|KENTUCKY|BEMBOS|MCDON|NORKY|TACO|FAST/.test(n)) return 'Fast food';
  if(/POLLO|POLLERIA|POLLIZ|PARDO|SHORTON|ROKY|TORI|PIO PIO|CHICKEN|MEGA POLLO/.test(n)) return 'Pollería';
  if(/HOTEL|TURISMO|VIAJE|AVENTURAS/.test(n)) return 'Hotel';
  if(/SALCHIPAPA|SNACK/.test(n)) return 'Snacks';
  if(/GRILL|PARRILLA|ASADO|TIMBO/.test(n)) return 'Parrilla';
  return 'Restaurante';
}

