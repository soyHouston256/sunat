async function downloadSlide(){
  const btn = $('storyDlBtn');
  btn.disabled = true;
  btn.innerHTML = '⏳ Generando...';

  // Capture the active slide that's already rendered in the DOM
  const activeSlide = $('storiesSlides').querySelector('.story-slide.active');
  if(!activeSlide){
    btn.disabled = false;
    btn.innerHTML = '<span class="dl-icon">📥</span> Guardar imagen';
    return;
  }

  // Temporarily hide UI overlays so they don't appear in screenshot
  const dlBtn = $('storyDlBtn');
  const tapHint = $('tapHint');
  const yapeCorner = activeSlide.closest('#storiesScreen')?.querySelector('.yape-corner');
  if(dlBtn) dlBtn.style.visibility = 'hidden';
  if(tapHint) tapHint.style.visibility = 'hidden';
  if(yapeCorner) yapeCorner.style.visibility = 'hidden';

  try {
    const canvas = await html2canvas(activeSlide, {
      scale: 2,
      useCORS: true,
      allowTaint: true,
      logging: false,
      backgroundColor: null,
    });
    const blob = await new Promise((resolve, reject) => {
      canvas.toBlob(b => b ? resolve(b) : reject(new Error('toBlob devolvió null')), 'image/png');
    });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `sunat-wrapped-slide-${currentStory+1}.png`;
    document.body.appendChild(a);
    a.click();
    setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(url); }, 200);
    btn.innerHTML = '✅ ¡Guardada!';
    setTimeout(()=>{ btn.disabled=false; btn.innerHTML='<span class="dl-icon">📥</span> Guardar imagen'; }, 2000);
  } catch(e){
    btn.disabled = false;
    btn.innerHTML = '<span class="dl-icon">📥</span> Guardar imagen';
    alert('Error al generar imagen: ' + e.message);
  } finally {
    if(dlBtn) dlBtn.style.visibility = '';
    if(tapHint) tapHint.style.visibility = '';
    if(yapeCorner) yapeCorner.style.visibility = '';
  }
}


function openStories(){
  $('storiesScreen').style.display='flex';
  document.body.style.overflow='hidden';
  renderStories();
  goToStory(0);
}

function closeStories(){
  clearTimeout(storyTimer);
  $('storiesScreen').style.display='none';
  document.body.style.overflow='';
}

function renderStories(){
  const slides = buildStorySlides(storyData);
  $('storiesSlides').innerHTML = slides.join('');
  // progress bars
  $('storiesProgress').innerHTML = slides.map((_,i)=>
    `<div class="story-prog-bar"><div class="story-prog-fill" id="prog${i}"></div></div>`
  ).join('');
}

function goToStory(idx){
  const tb=document.getElementById("slideTransBar");
  if(tb){tb.classList.remove("go");void tb.offsetWidth;tb.classList.add("go");}
  clearTimeout(storyTimer);
  const slides = $('storiesSlides').querySelectorAll('.story-slide');
  const n = slides.length;
  if(idx < 0){ closeStories(); return; }
  if(idx >= n){ closeStories(); return; }

  slides.forEach((s,i)=>{
    s.classList.remove('active','exit-left');
    if(i < idx) s.classList.add('exit-left');
  });
  slides[idx].classList.add('active');
  currentStory = idx;

  // animate emoji
  const em = slides[idx].querySelector('.s-emoji');
  if(em){ em.classList.remove('go'); void em.offsetWidth; em.classList.add('go'); }

  // Stop previous gold rain
  if(stopGoldRain){ stopGoldRain(); stopGoldRain=null; }

  setTimeout(()=>{
    // Slide 2 — counter + gold rain
    if(idx===1){
      const el = $('counterTotal');
      if(el) animateCounter(el, el.dataset.target);
      stopGoldRain = startGoldRain('goldRainCanvas');
    }
    // Slide 5 — escudo + comp bar
    if(idx===4){
      const bar = $('storyCompBar');
      if(bar) bar.style.width = Math.min(90, Math.round(storyData.totalBase/8500*60))+'%';
      const esc = $('escudoWrap');
      if(esc){ esc.classList.remove('go'); void esc.offsetWidth; esc.classList.add('go'); }
    }
  }, 350);

  // progress bars
  for(let i=0;i<n;i++){
    const pf = $('prog'+i);
    if(!pf) continue;
    pf.classList.remove('active','done');
    pf.style.animation='none';
    void pf.offsetWidth;
    if(i < idx){ pf.classList.add('done'); }
    else if(i === idx){
      pf.style.animation='';
      pf.style.setProperty('--story-duration', STORY_DURATION+'ms');
      pf.classList.add('active');
    }
  }

  storyTimer = setTimeout(()=>goToStory(idx+1), STORY_DURATION);
}

function nextStory(){ goToStory(currentStory+1); }
function prevStory(){ goToStory(currentStory-1); }

// swipe support
let touchX=0;
document.addEventListener('touchstart',e=>{ touchX=e.touches[0].clientX; });
document.addEventListener('touchend',e=>{
  if($('storiesScreen').style.display!=='flex') return;
  const dx=e.changedTouches[0].clientX - touchX;
  if(Math.abs(dx)>40){ dx<0?nextStory():prevStory(); }
});

// keyboard navigation
document.addEventListener('keydown',e=>{
  if($('storiesScreen').style.display!=='flex') return;
  if(e.key==='ArrowRight'||e.key==='ArrowDown') nextStory();
  else if(e.key==='ArrowLeft'||e.key==='ArrowUp') prevStory();
  else if(e.key==='Escape') $('storiesScreen').style.display='none';
});

// ── CONFETTI ──
function launchConfetti(){
  const canvas=$('confettiCanvas');
  canvas.width=window.innerWidth; canvas.height=window.innerHeight;
  const ctx=canvas.getContext('2d');
  const colors=['#FF6B35','#FFD23F','#06D6A0','#B388FF','#FF6B9D','#4FC3F7'];
  const parts=Array.from({length:120},()=>({
    x:Math.random()*canvas.width,y:-10,w:Math.random()*10+4,h:Math.random()*6+4,
    color:colors[Math.floor(Math.random()*colors.length)],
    rot:Math.random()*360,vx:(Math.random()-.5)*3,vy:Math.random()*4+2,vr:(Math.random()-.5)*6
  }));
  let frame=0;
  function tick(){
    if(frame++>180){ctx.clearRect(0,0,canvas.width,canvas.height);return;}
    ctx.clearRect(0,0,canvas.width,canvas.height);
    parts.forEach(p=>{
      p.x+=p.vx;p.y+=p.vy;p.rot+=p.vr;p.vy+=0.05;
      ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.rot*Math.PI/180);
      ctx.fillStyle=p.color;ctx.globalAlpha=Math.max(0,1-frame/180);
      ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();
    });
    requestAnimationFrame(tick);
  }
  tick();
}

