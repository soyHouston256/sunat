// ── COMPARATIVA NACIONAL (datos referenciales graciosos) ──
function buildComparativa(data){
  const avg = 8500; // promedio nacional anual estimado deducible restaurantes
  const pct = Math.min(99, Math.round((data.totalBase / avg) * 50));
  const ticketNac = 45;
  const tuTicket = data.totalBase / data.totalCount;
  const mesesNac = 8; // promedio meses con gasto
  const tusMeses = data.monthBase.filter(v=>v>0).length;

  const rows = [
    {
      icon:'🇵🇪',
      title:'Gasto vs. el contribuyente promedio',
      you: Math.min(100, Math.round(data.totalBase/avg*60)),
      prom: 40,
      youColor:'#FF6B35',promColor:'#4FC3F7',
      verdict: data.totalBase > avg
        ? `Gastas ${((data.totalBase/avg-1)*100).toFixed(0)}% más que el limeño promedio. La SUNAT te conoce bien.`
        : `Gastas menos que el promedio. La SUNAT apenas sabe que existes — y eso no es malo.`
    },
    {
      icon:'🍽️',
      title:'Ticket promedio vs. promedio nacional',
      you: Math.min(100,Math.round(tuTicket/ticketNac*50)),
      prom: 50,
      youColor:'#FFD23F',promColor:'#4FC3F7',
      verdict: tuTicket > ticketNac
        ? `Tu ticket de ${fmtSol(tuTicket)} supera los S/45 del peruano promedio. No eres de los que piden solo el menú ejecutivo.`
        : `Tu ticket de ${fmtSol(tuTicket)} está por debajo del promedio. Eficiencia máxima al comer.`
    },
    {
      icon:'📆',
      title:'Meses activos vs. promedio nacional',
      you: Math.round(tusMeses/12*100),
      prom: Math.round(mesesNac/12*100),
      youColor:'#06D6A0',promColor:'#4FC3F7',
      verdict: tusMeses >= mesesNac
        ? `${tusMeses} meses con boletas. Más constante que la mayoría — o simplemente nunca cocinaste en casa.`
        : `${tusMeses} meses con boletas. Algunos meses te portaste bien, o simplemente no saliste.`
    },
  ];

  $('compNacional').innerHTML = rows.map(r=>`
    <div class="comp-row">
      <div class="comp-icon">${r.icon}</div>
      <div class="comp-info">
        <div class="comp-title">${r.title}</div>
        <div class="comp-bar-t">
          <div class="comp-bar-f" style="width:${r.you}%;background:${r.youColor};" data-w="${r.you}"></div>
        </div>
        <div class="comp-verdict">${r.verdict}</div>
      </div>
    </div>`).join('');

  // animate bars on scroll
  setTimeout(()=>{
