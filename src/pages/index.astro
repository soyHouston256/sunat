    {emoji:'📅',val:meses[maxMes],lbl:`fue tu mes más gastador (${fmtSol(monthBase[maxMes])})`},
    {emoji:'📍',val:(topLugar?.[0]||'').split(' ').slice(0,2).join(' '),lbl:`es donde más plata dejaste (${fmtSol(topLugar?.[1]||0)})`},
