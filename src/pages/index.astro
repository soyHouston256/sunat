      </div>
      <div class="sc-viral">"${viralPhrases[selectedPhrase]}"</div>
      <div class="sc-tag">#SUNATWrapped2025 · sunat.maxflow.ink</div>
    `;
  }
  renderShareCard();

  // Render viral phrase selector
  $('viralPhrases').innerHTML = viralPhrases.map((p,i)=>
    `<button class="viral-pill${i===0?' active':''}" onclick="selectPhrase(${i})">${p.substring(0,55)}${p.length>55?'…':''}</button>`
